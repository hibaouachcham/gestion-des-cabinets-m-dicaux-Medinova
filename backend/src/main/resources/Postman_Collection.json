            },
            "url": {
              "raw": "{{baseUrl}}/api/consultations",
              "host": ["{{baseUrl}}"],
              "path": ["api", "consultations"]
            }
          }
        }
      ]
    },
    {
      "name": "Factures",
      "item": [
        {
          "name": "Get Factures",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/factures?page=0&size=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "factures"],
              "query": [
                {"key": "page", "value": "0"},
                {"key": "size", "value": "10"}
              ]
            }
          }
        },
        {
          "name": "Create Facture",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {"key": "patientId", "value": "1"},
                {"key": "montantHT", "value": "500"},
                {"key": "tauxTVA", "value": "0.20"}
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/factures",
              "host": ["{{baseUrl}}"],
              "path": ["api", "factures"]
            }
          }
        },
        {
          "name": "Generate PDF",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/factures/1/pdf",
              "host": ["{{baseUrl}}"],
              "path": ["api", "factures", "1", "pdf"]
            }
          }
        }
      ]
    },
    {
      "name": "Médicaments",
      "item": [
        {
          "name": "Search Medicaments",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/medicaments?q=para",
              "host": ["{{baseUrl}}"],
              "path": ["api", "medicaments"],
              "query": [{"key": "q", "value": "para"}]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
