            }
          }
        },
        {
          "name": "Create Rendez-vous",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patientId\": 1,\n  \"dateHeure\": \"2024-12-25T10:00:00\",\n  \"motif\": \"Consultation de suivi\",\n  \"statut\": \"PLANIFIE\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/rendezvous",
              "host": ["{{baseUrl}}"],
              "path": ["api", "rendezvous"]
            }
          }
        }
      ]
    },
    {
      "name": "Consultations",
      "item": [
        {
          "name": "Create Consultation",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {"key": "patientId", "value": "1"},
                {"key": "motif", "value": "Consultation générale"},
                {"key": "diagnostic", "value": "Diagnostic"},
                {"key": "prescription", "value": "Prescription"}
