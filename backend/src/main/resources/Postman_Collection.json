{
  "info": {
    "name": "Medinova API",
    "description": "Collection Postman pour l'API Medinova",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"passwordAdmin\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "me"]
            }
          }
        },
        {
          "name": "Get CSRF Token",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/auth/csrf",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "csrf"]
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "logout"]
            }
          }
        }
      ]
    },
    {
      "name": "Patients",
      "item": [
        {
          "name": "Get Patients",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/patients?page=0&size=10&search=",
              "host": ["{{baseUrl}}"],
              "path": ["api", "patients"],
              "query": [
                {"key": "page", "value": "0"},
                {"key": "size", "value": "10"},
                {"key": "search", "value": ""}
              ]
            }
          }
        },
        {
          "name": "Get Patient by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/patients/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "patients", "1"]
            }
          }
        },
        {
          "name": "Create Patient",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cin\": \"AB999999\",\n  \"nom\": \"Test\",\n  \"prenom\": \"Patient\",\n  \"sexe\": \"M\",\n  \"telephone\": \"0612345678\",\n  \"email\": \"test@example.com\",\n  \"adresse\": \"123 Rue Test\",\n  \"ville\": \"Casablanca\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/patients",
              "host": ["{{baseUrl}}"],
              "path": ["api", "patients"]
            }
          }
        },
        {
          "name": "Enqueue Patient",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/patients/1/enqueue",
              "host": ["{{baseUrl}}"],
              "path": ["api", "patients", "1", "enqueue"]
            }
          }
        }
      ]
    },
    {
      "name": "Rendez-vous",
      "item": [
        {
          "name": "Get Rendez-vous",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/rendezvous?page=0&size=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "rendezvous"],
              "query": [
                {"key": "page", "value": "0"},
                {"key": "size", "value": "10"}
